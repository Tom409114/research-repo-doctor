{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Tom409114/rrdoctor",
  "title": "Research Repo Doctor",
  "description": "Deterministic Artifact Evaluation preflight and run-path grader for research repositories.",
  "version": "0.2.22",
  "repository": {
    "url": "https://github.com/Tom409114/research-repo-doctor",
    "source": "github"
  },
  "websiteUrl": "https://github.com/Tom409114/research-repo-doctor/blob/main/docs/mcp.md",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "rrdoctor",
      "version": "0.2.22",
      "runtimeHint": "uvx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "--from"
        },
        {
          "type": "positional",
          "value": "rrdoctor[mcp]==0.2.22"
        },
        {
          "type": "positional",
          "value": "rrdoctor"
        }
      ],
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
